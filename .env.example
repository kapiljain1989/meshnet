# ─────────────────────────────────────────────────────────────────────────────
# MeshNet — Environment Variables
# Copy to .env and fill in your values: cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# Your Headscale control plane domain (DNS A record → VPS public IP)
HEADSCALE_DOMAIN=hs.yourdomain.com

# Your admin UI domain (DNS A record → same VPS public IP)
UI_DOMAIN=ui.yourdomain.com

# Email for Let's Encrypt certificate notifications
ACME_EMAIL=admin@yourdomain.com